INSTANCE_NAME=Factory 1
NEXT_PUBLIC_INSTANCE_NAME=Factory 1

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Server-only. Preferred — bypasses RLS, so the app works regardless of
# whether RLS is enabled on product_inventory.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Fallback. Used only when SUPABASE_SERVICE_ROLE_KEY is not set.
# Requires RLS to be off OR a policy that lets `anon` read/write.
SUPABASE_ANON_KEY=your-anon-key

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
